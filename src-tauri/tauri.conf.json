{
  "$schema": "https://schema.tauri.app/config/2.10.3",
  "productName": "Clipboard Cleaner",
  "version": "0.1.0",
  "identifier": "com.masmoriya.clipboard-cleaner",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": [
        "main-capability"
      ]
    },
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "title": "Clipboard Cleaner",
        "visible": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "width": 360,
        "height": 560,
        "alwaysOnTop": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon@2x.png",
      "icons/icon.png"
    ],
    "category": "public.app-category.utilities",
    "shortDescription": "Sanitize clipboard text before pasting.",
    "longDescription": "Clipboard Cleaner watches the macOS clipboard, applies deterministic sanitization rules, and writes cleaned text back when it changes."
  },
  "plugins": {
    "clipboard-manager": null
  }
}
