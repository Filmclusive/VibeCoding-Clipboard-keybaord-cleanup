{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Clipboard Cleaner runtime capability for tray + clipboard access.",
  "windows": ["main"],
  "platforms": ["macOS"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:menu:default",
    "core:tray:default",
    "core:resources:default",
    "core:app:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
